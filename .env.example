# =============================================================================
# BizMind Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://bizmind:bizmind@localhost:5433/bizmind

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=bizmind_chunks

# --- File Storage ---
STORAGE_PATH=./data/uploads
MAX_UPLOAD_SIZE_MB=20

# --- LLM (OpenAI-compatible, default DeepSeek) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# --- Embedding (default SiliconFlow BGE-M3) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# --- RAG ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
PARENT_CHUNK_SIZE=2048
RETRIEVAL_TOP_K=20
RERANK_TOP_K=4
RERANK_PROVIDER=local
# RERANK_PROVIDER=cohere
# COHERE_API_KEY=

# --- Agent ---
MAX_RETRIEVAL_RETRIES=2
MAX_CRITIQUE_RETRIES=1
GRADE_THRESHOLD=0.5
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=

# --- Auth ---
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Observability (optional) ---
# docker compose -f docker-compose.yml -f docker-compose.observability.yml --profile observability up -d
# Create DB: docker exec bizmind-postgres-1 psql -U bizmind -c "CREATE DATABASE bizmind_langfuse"
# Then set LANGFUSE_ENABLED=true and keys from Langfuse UI (http://localhost:3001)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_ENABLED=false

# --- Frontend (build-time) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
